rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email']) &&
        request.resource.data.uid == userId;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'email']);
    }

    // Global Routes
    match /routes/{routeId} {
      allow list, get: if true; // Everyone can see global traffic
      allow create, update: if true; // Allow public simulation and position updates
      allow delete: if isSignedIn(); // Only staff can delete
    }

    // Notifications
    match /notifications/{notifId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Systems or users can create alerts
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
